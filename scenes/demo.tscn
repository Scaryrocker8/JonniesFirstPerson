[sub_resource type="GDScript" id="GDScript_b0nem"]
script/source = "extends RigidBody3D
class_name GoldenDonut

@export var congradulations: CenterContainer

var donut_grabbed: bool = false

func _ready() -> void:
	congradulations.visible = false

# Here's an example of an interact function applied to a PhysicsBody3D
func interact() -> void:
	if !donut_grabbed:
		donut_grabbed = true
		congradulations.visible = true
		await get_tree().create_timer(5.0).timeout
		congradulations.visible = false
"

